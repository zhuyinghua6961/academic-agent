{
  "name": "academic-agent",
  "private": true,
  "packageManager": "pnpm@11.3.0+sha512.2c403d6594527287672b1f7056343a1f7c3634036a67ffabfcc2b3d7595d843768f8787148d1b57cf7956c90606bbd192857c363af19e96d2d0ec9ec5741d215",
  "bin": {
    "academic-agent": "./bin/academic-agent.mjs"
  },
  "scripts": {
    "tui": "pnpm --filter @academic-agent/app start",
    "cli": "node ./bin/academic-agent.mjs",
    "dev": "pnpm --filter @academic-agent/app dev",
    "typecheck": "pnpm -r typecheck",
    "test": "vitest run && node --test bin/academic-agent-runtime.test.mjs && pnpm --filter @academic-agent/app test",
    "test:watch": "vitest",
    "build": "pnpm -r run build"
  },
  "devDependencies": {
    "@academic-agent/agent-core": "workspace:*",
    "@academic-agent/config": "workspace:*",
    "@academic-agent/setup": "workspace:*",
    "@academic-agent/workspace": "workspace:*",
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
