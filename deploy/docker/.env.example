# Academic Agent — Docker Compose environment
# Copy to .env and adjust secrets for local development.

COMPOSE_PROJECT_NAME=academic-agent

POSTGRES_USER=academic
POSTGRES_PASSWORD=academic_dev_password
POSTGRES_DB=academic_agent

REDIS_PASSWORD=

KAFKA_BROKERS=kafka:9092

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=academic-agent

JWT_SECRET=change-me-in-production-use-long-random-string
CREDENTIALS_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

PLATFORM_JAVA_IMAGE=academic-agent/platform-java:local
AGENT_RUNTIME_IMAGE=academic-agent/agent-runtime:local
WEB_IMAGE=academic-agent/web:local

PLATFORM_INTERNAL_TOKEN=dev-internal-token-change-in-prod
